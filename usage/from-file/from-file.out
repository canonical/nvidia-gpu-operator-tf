      repository: nvcr.io/nvidia/cloud-native
      version: v0.8.0
    nvidiaDriverCRD:
      deployDefaultCR: true
      driverType: gpu
      enabled: false
      nodeSelector: {}
    rdma:
      enabled: false
      useHostMofed: false
    repoConfig:
      configMapName: ""
    repository: nvcr.io/nvidia
    resources: {}
    startupProbe:
      failureThreshold: 120
      initialDelaySeconds: 60
      periodSeconds: 10
      timeoutSeconds: 60
    upgradePolicy:
      autoUpgrade: true
      drain:
        deleteEmptyDir: false
        enable: false
        force: false
        podSelector: ""
        timeoutSeconds: 300
      gpuPodDeletion:
        deleteEmptyDir: false
        force: false
        timeoutSeconds: 300
      maxParallelUpgrades: 1
      maxUnavailable: 25%
      waitForCompletion:
        podSelector: ""
        timeoutSeconds: 0
    usePrecompiled: false
    version: 570.148.08
    virtualTopology:
      config: ""
  gdrcopy:
    args: []
    enabled: false
    env: []
    image: gdrdrv
    imagePullPolicy: IfNotPresent
    imagePullSecrets: []
    repository: nvcr.io/nvidia/cloud-native
