          weight: 1
        - preference:
            matchExpressions:
            - key: node-role.kubernetes.io/control-plane
              operator: In
              values:
              - ""
          weight: 1
    annotations:
      openshift.io/scc: restricted-readonly
    cleanupCRD: false
    defaultRuntime: containerd
    image: gpu-operator
